generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id          String   @id @default(uuid())
  nameEn      String
  nameZh      String
  titleEn     String
  titleZh     String
  subtitleEn  String
  subtitleZh  String
  descriptionEn String
  descriptionZh String
  location    String
  email       String
  languages   String
  linkedinUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Venture {
  id          String   @id @default(uuid())
  name        String
  nameZh      String
  tag         String
  tagZh       String
  summaryEn   String
  summaryZh   String
  status      String   // Live, Demo, Internal, In Development, Legacy, Coming Soon
  statusZh    String
  link        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Honor {
  id          String   @id @default(uuid())
  title       String
  titleZh     String
  year        String
  organization String
  organizationZh String
  subtitle    String
  subtitleZh  String
  link        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaMention {
  id          String   @id @default(uuid())
  title       String
  titleZh     String
  source      String
  sourceZh    String?
  date        String
  summaryEn   String
  summaryZh   String
  link        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicLink {
  id          String   @id @default(uuid())
  title       String
  titleZh     String
  url         String
  type        String   // linkedin, company, media, community
  description String
  descriptionZh String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SearchKeyword {
  id          String   @id @default(uuid())
  keyword     String
  keywordZh   String?
  category    String   // name, company, project
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimelineItem {
  id          String   @id @default(uuid())
  period      String
  periodZh    String
  event       String
  eventZh     String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Capability {
  id          String   @id @default(uuid())
  title       String
  titleZh     String
  description String
  descriptionZh String
  icon        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CollaborationItem {
  id          String   @id @default(uuid())
  title       String
  titleZh     String
  description String
  descriptionZh String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stat {
  id          String   @id @default(uuid())
  value       String
  labelEn     String
  labelZh     String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
